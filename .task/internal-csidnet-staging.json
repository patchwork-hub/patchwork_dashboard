{
    "family": "csidnet-dashboard",
    "containerDefinitions": [
        {
            "name": "csidnet-dashboard",
            "image": "672691776916.dkr.ecr.eu-west-2.amazonaws.com/internal-patchwork-dashboard:production",
            "cpu": 0,
            "portMappings": [
                {
                    "name": "csidnet-dashboard-3000-tcp",
                    "containerPort": 3000,
                    "hostPort": 3000,
                    "protocol": "tcp",
                    "appProtocol": "http"
                }
            ],
            "essential": true,
            "environment": [],
            "environmentFiles": [
                {
                    "value": "arn:aws:s3:::patchwork-private-env/csidnet-dashboard.env",
                    "type": "s3"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/csidnet-dashboard",
                    "awslogs-create-group": "true",
                    "awslogs-region": "eu-west-2",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "systemControls": []
        }
    ],
    "taskRoleArn": "arn:aws:iam::672691776916:role/patchwork-ecs-task-role",
    "executionRoleArn": "arn:aws:iam::672691776916:role/patchwork-ecs-task-execution-role",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "512",
    "memory": "1024",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    },
    "enableFaultInjection": false
}